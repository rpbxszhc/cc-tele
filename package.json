{
  "name": "cc-tele",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted Telegram bridge for Claude Code using a local Claude CLI provider config.",
  "scripts": {
    "start": "NODE_NO_WARNINGS=1 node src/index.js",
    "check": "find src -name '*.js' -exec node --check {} \\; && node src/index.js --check-config"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "telegraf": "^4.16.3"
  },
  "engines": {
    "node": ">=20"
  }
}
