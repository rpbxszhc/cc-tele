# Copy to .env and chmod 600 .env.
# You can reuse ~/.claude/channels/telegram/.env for the token value.
TELEGRAM_BOT_TOKEN=

# Claude Code provider env. This file is sourced before each claude invocation.
CLAUDE_ENV_FILE=~/.claude.sh

# Claude Code workspace policy. /cwd can switch only to these real directories.
DEFAULT_CWD=~/z/cc-tele
ALLOWED_WORKSPACES=~/z/*

# Claude Code execution.
CLAUDE_PERMISSION_MODE=auto
CLAUDE_TIMEOUT_MS=1800000

# PTY-backed interactive sessions.
ENABLE_PTY=true
PTY_OUTPUT_MODE=image
PTY_OUTPUT_INTERVAL_MS=1200
PTY_IMAGE_THEME=light
PTY_IMAGE_FONT_SIZE=20
PTY_SCREEN_LINES=80
PTY_ROWS=30
PTY_COLS=54
PTY_IDLE_TIMEOUT_MS=1800000
PTY_HARD_TIMEOUT_MS=0

# Optional remote shell command execution via /sh <command>, backed by PTY.
# Keep disabled unless the Telegram bot token is treated as full machine access.
ENABLE_SHELL_COMMANDS=false

# Telegram output splitting. Keep under Telegram's 4096 character text limit.
MESSAGE_CHUNK_SIZE=3500

# Local state file.
STATE_FILE=./data/state.json
